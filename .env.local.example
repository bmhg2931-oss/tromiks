# העתק/י קובץ זה ל-.env.local ומלא/י את הערכים מתוך Supabase:
# Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# סליקת אשראי נדרים פלוס (matara.pro) - יש לבקש מהמשרד שלהם
# ה-ApiValid אינו סוד שרת: הוא נשלח מהדפדפן ישירות לאייפרם שלהם (בדיוק כמו בדוגמה הרשמית שלהם)
NEXT_PUBLIC_NEDARIM_MOSAD=YOUR-7-DIGIT-MOSAD-ID
NEXT_PUBLIC_NEDARIM_API_VALID=YOUR-API-VALID-TOKEN

# מפתח API של Anthropic (Claude) - להפעלת צ'אט ה-AI. מ-console.anthropic.com
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY

# שליחת מיילים אמיתית מתוך קמפיינים, דרך Resend (resend.com)
RESEND_API_KEY=YOUR-RESEND-API-KEY
RESEND_FROM_EMAIL=onboarding@resend.dev

# שיחות VoIP אמיתיות מהדפדפן דרך Twilio Voice (console.twilio.com)
# TWILIO_TWIML_APP_SID: יש ליצור TwiML App עם Voice Request URL שמצביע ל-
#   https://<הכתובת-הציבורית-שלך>/api/twilio-voice (לא יעבוד מול localhost בלבד - נדרש ngrok/פריסה)
TWILIO_ACCOUNT_SID=YOUR-TWILIO-ACCOUNT-SID
TWILIO_API_KEY_SID=YOUR-TWILIO-API-KEY-SID
TWILIO_API_KEY_SECRET=YOUR-TWILIO-API-KEY-SECRET
TWILIO_TWIML_APP_SID=YOUR-TWILIO-TWIML-APP-SID
TWILIO_CALLER_ID=+972XXXXXXXXX
